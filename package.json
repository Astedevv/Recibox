 {
  "name": "recibox",
  "version": "1.0.3",
  "description": "ReciBox desktop app for supplier payments and receipts",
  "main": "out/main/index.js",
  "author": "ReciBox",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:v3": "npm run build && npx --yes electron-builder --config release/builder-effective-config.yaml --win --x64 --dir --config.directories.output=desktop-build-v3",
    "installer:v3": "pwsh -Command \"$env:RECIBOX_BUILD_DIR='desktop-build-v3\\win-unpacked'; $env:RECIBOX_INSTALLER_OUT_DIR='desktop-build-v3\\installer'; & 'scripts\\build-installer.ps1'\"",
    "dist:v3": "npm run build:v3 && npm run installer:v3",
    "build:v4": "npm run build && npx --yes electron-builder --config release/builder-effective-config.yaml --win --x64 --dir --config.directories.output=desktop-build-v4",
    "installer:v4": "pwsh -Command \"$env:RECIBOX_BUILD_DIR='desktop-build-v4\\win-unpacked'; $env:RECIBOX_INSTALLER_OUT_DIR='desktop-build-v4\\installer'; & 'scripts\\build-installer.ps1'\"",
    "dist:v4": "npm run build:v4 && npm run installer:v4",
    "dist": "npm run build && pwsh -File scripts\\build-installer.ps1",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "lucide-react": "^0.511.0",
    "puppeteer": "^24.10.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.3.0",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.4",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
